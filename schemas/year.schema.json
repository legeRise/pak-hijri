{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pak-hijri.local/schemas/year.schema.json",
  "title": "Pak Hijri Year Data",
  "type": "object",
  "required": [
    "country",
    "country_name",
    "hijri_year",
    "calendar_basis",
    "months"
  ],
  "properties": {
    "country": {
      "const": "PK"
    },
    "country_name": {
      "const": "Pakistan"
    },
    "hijri_year": {
      "type": "integer",
      "minimum": 1
    },
    "calendar_basis": {
      "const": "pakistan_moon_sighting"
    },
    "months": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": [
          "month",
          "month_name",
          "gregorian_start_date",
          "status",
          "confidence",
          "sources",
          "notes"
        ],
        "properties": {
          "month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "month_name": {
            "type": "string",
            "minLength": 1
          },
          "gregorian_start_date": {
            "type": "string",
            "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "status": {
            "enum": [
              "pending",
              "verified",
              "estimated",
              "disputed"
            ]
          },
          "confidence": {
            "enum": [
              "unknown",
              "low",
              "medium",
              "high"
            ]
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "source_name"
              ],
              "properties": {
                "title": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                },
                "published_at": {
                  "type": "string",
                  "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
                },
                "source_name": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
